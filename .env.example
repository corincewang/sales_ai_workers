# Copy this file to `.env` and fill in secrets. `.env` is gitignored.

# PostgreSQL (Postgres.app / Docker / cloud)
DATABASE_URL="postgresql://YOUR_USER@localhost:5432/sales_ai?schema=public"

# OpenAI (Hour 2 — insights). Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Insight model — team default `gpt-4o-mini` (see src/lib/generate-lead-insight.ts). Override if needed.
OPENAI_MODEL=gpt-4o-mini

# Prompt template version (stored on LeadInsight)
INSIGHT_PROMPT_VERSION=v1

# Hour 3 — GAF contractor list is served via Coveo Search API v2 (POST + JSON body + Bearer).
# Search URL pattern:
#   https://platform.cloud.coveo.com/rest/search/v2?organizationId=<orgId>
# Default org id is in src/lib/scrape/gaf-discovery.ts (GAF_COVEO_ORGANIZATION_ID).
# GAF_COVEO_ORGANIZATION_ID=gafmaterialscorporationproduction3yalqk12

# Paste Authorization Bearer value from DevTools for the search request (expires; demo/local only).
# GAF_COVEO_BEARER_TOKEN=

# Optional full Search v2 URL (defaults to org id in gaf-discovery.ts).
# GAF_COVEO_SEARCH_V2_URL=https://platform.cloud.coveo.com/rest/search/v2?organizationId=gafmaterialscorporationproduction3yalqk12

# Hour 3-2 — gaf-client.ts (politeness + retries)
# GAF_SCRAPE_USER_AGENT=SalesAIWorkers/0.1 (case study)
# GAF_SCRAPE_REQUEST_DELAY_MS=0
# GAF_SCRAPE_MAX_RETRIES=3
# GAF_SCRAPE_RETRY_BASE_MS=1000

# Optional page size for npm run scrape:gaf (Coveo numberOfResults; max 200 clamp).
# GAF_SCRAPE_PAGE_SIZE=100

# POST /api/admin/scrape — set in production; send header `x-admin-scrape-secret: <same value>`.
# SCRAPE_ADMIN_SECRET=

# After scrape: sequential OpenAI insight batch (ms between calls). Used by admin route + optional CLI.
# GAF_INSIGHT_DELAY_MS=1200

# CLI only: set to 1 to run batch insights after upsert (needs OPENAI_API_KEY). Default: scrape only.
# GAF_SCRAPE_GENERATE_INSIGHTS=0
# Set to 1 to regenerate even when a LeadInsight row already exists (CLI batch only).
# GAF_SCRAPE_INSIGHTS_REGENERATE=0

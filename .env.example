# Copy this file to `.env` and fill in secrets. `.env` is gitignored.

# PostgreSQL (Postgres.app / Docker / cloud)
DATABASE_URL="postgresql://YOUR_USER@localhost:5432/sales_ai?schema=public"

# OpenAI (Hour 2 — insights). Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional — used when calling the API and stored on LeadInsight for audit (defaults in code if unset)
# OPENAI_MODEL=gpt-4o-mini
# INSIGHT_PROMPT_VERSION=v1
